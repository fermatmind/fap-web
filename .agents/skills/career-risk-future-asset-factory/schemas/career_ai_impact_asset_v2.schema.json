{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Career AI Impact Reader Asset v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ledger_type",
    "asset_version",
    "block_type",
    "slug",
    "locale",
    "locale_market_context",
    "occupation",
    "seed_ordinal",
    "batch_role",
    "summary",
    "items",
    "sources",
    "workflow_evidence_items",
    "external_calibration_sources",
    "score_rationale",
    "ai_exposure_score",
    "reader_boundary",
    "evidence_used",
    "derived_from_synthesis",
    "template_signature",
    "repeated_template_risk",
    "occupation_specificity_score",
    "locale_independence_score",
    "search_projection",
    "audit_fields"
  ],
  "properties": {
    "ledger_type": { "const": "career-ai-impact_asset" },
    "asset_version": { "type": "string", "pattern": "^v2" },
    "block_type": { "const": "career-risk-future.ai_impact" },
    "slug": { "type": "string", "minLength": 1 },
    "locale": { "type": "string", "enum": ["zh-CN", "en"] },
    "locale_market_context": { "type": "object" },
    "occupation": { "type": "object" },
    "seed_ordinal": { "type": "integer", "minimum": 1 },
    "batch_role": { "type": "string", "pattern": "^(control|new)_[0-9]+$" },
    "summary": { "type": "string", "minLength": 1 },
    "items": { "type": "array", "minItems": 3, "items": { "type": "object" } },
    "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/sourceObject" } },
    "workflow_evidence_items": { "type": "array", "minItems": 4, "items": { "type": "object" } },
    "external_calibration_sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/sourceObject" } },
    "score_rationale": { "$ref": "#/$defs/scoreRationale" },
    "ai_exposure_score": { "type": "object" },
    "reader_boundary": { "type": "string", "minLength": 1 },
    "evidence_used": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "derived_from_synthesis": { "type": "object" },
    "template_signature": { "type": "string", "minLength": 1 },
    "repeated_template_risk": { "type": "boolean" },
    "occupation_specificity_score": { "type": "integer", "minimum": 0, "maximum": 5 },
    "locale_independence_score": { "type": "integer", "minimum": 0, "maximum": 5 },
    "search_projection": { "$ref": "#/$defs/searchProjection" },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "audit_fields": { "type": "object" }
  },
  "$defs": {
    "sourceObject": {
      "type": "object",
      "required": ["source_id", "name", "publisher", "url", "source_type", "used_for", "evidence_scope", "citation_boundary", "captured_at"]
    },
    "scoreRationale": {
      "type": "object",
      "required": [
        "score_1_to_10",
        "score_band",
        "exposure_type",
        "confidence",
        "task_exposure_drivers",
        "human_judgment_anchors",
        "why_not_higher",
        "why_not_lower",
        "confidence_reason",
        "evidence_ids_used",
        "external_calibration_source_ids_used",
        "internal_rubric_source_id",
        "manual_review_flag",
        "manual_review_reason"
      ]
    },
    "searchProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_status",
        "runtime_use_boundary",
        "citation_snippets"
      ],
      "properties": {
        "projection_status": { "const": "candidate_only_not_runtime_seo" },
        "runtime_use_boundary": { "type": "string", "minLength": 1 },
        "seo_title_candidate": { "type": ["string", "null"] },
        "meta_description_candidate": { "type": ["string", "null"] },
        "answer_snippets": { "type": "array", "items": { "type": "string" } },
        "entity_terms": { "type": "array", "items": { "type": "string" } },
        "faq_questions": { "type": "array", "items": { "type": "string" } },
        "citation_claims": { "type": "array", "items": { "type": "string" } },
        "citation_snippets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["snippet", "source_ids"],
            "properties": {
              "snippet": { "type": "string", "minLength": 1 },
              "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
