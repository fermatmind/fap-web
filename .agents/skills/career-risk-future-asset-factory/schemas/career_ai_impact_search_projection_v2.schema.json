{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Career AI Impact Search Projection v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "locale",
    "projection_status",
    "runtime_use_boundary",
    "citation_snippets"
  ],
  "properties": {
    "slug": { "type": "string", "minLength": 1 },
    "locale": { "type": "string", "enum": ["zh-CN", "en"] },
    "projection_status": { "const": "candidate_only_not_runtime_seo" },
    "runtime_use_boundary": { "type": "string", "minLength": 1 },
    "seo_title_candidate": { "type": ["string", "null"] },
    "meta_description_candidate": { "type": ["string", "null"] },
    "answer_snippets": { "type": "array", "items": { "type": "string" } },
    "entity_terms": { "type": "array", "items": { "type": "string" } },
    "faq_questions": { "type": "array", "items": { "type": "string" } },
    "citation_claims": { "type": "array", "items": { "type": "string" } },
    "citation_snippets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["snippet", "source_ids"],
        "properties": {
          "snippet": { "type": "string", "minLength": 1 },
          "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    }
  }
}
