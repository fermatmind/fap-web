    },
    {
      "surface_key": "pdf",
      "fixture": "tests/fixtures/riasec/result_page_v2/pdf_ias_staging_payload.v0_1.json",
      "expected_terms": ["RIASEC PDF", "研究型", "艺术型", "社会型"],
      "expected_assertion": "renders backend-authored PDF fixture without share block or internal metadata"
    },
    {
      "surface_key": "share",
      "fixture": "tests/fixtures/riasec/result_page_v2/share_ias_staging_payload.v0_1.json",
      "expected_terms": ["我更适合从观察、创作和支持他人的任务里理解职业方向"],
      "expected_assertion": "renders only share-safe summary text"
    },
    {
      "surface_key": "history",
      "fixture": "tests/fixtures/riasec/result_page_v2/history_ias_staging_payload.v0_1.json",
      "expected_terms": ["IAS", "本次结果保留为职业兴趣方向快照"],
      "expected_assertion": "renders compact history snapshot without detailed module content"
    },
    {
      "surface_key": "compare",
      "fixture": "tests/fixtures/riasec/result_page_v2/compare_ias_staging_payload.v0_1.json",
      "expected_terms": ["IAS", "适合与后续结果比较兴趣排序是否稳定"],
      "expected_assertion": "renders compare-safe summary without private measurement detail"
    }
  ],
  "access_redaction": {
    "locked": {
      "full_body_visible": false,
      "private_measurements_visible": false,
