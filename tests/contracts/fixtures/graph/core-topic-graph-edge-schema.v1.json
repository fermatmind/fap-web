{
  "version": "core_topic_graph.edge_schema.v1",
  "authority_model": {
    "graph_truth_owner": "backend_cms",
    "frontend_role": "deterministic_render_only",
    "forbidden_authorities": [
      "frontend_local_graph_authority",
      "frontend_hardcoded_graph_expansion",
      "ai_generated_graph_filler",
      "hidden_schema_graph_stuffing"
    ]
  },
  "entity_type_registry": [
    "topic",
    "test",
    "personality_type",
    "trait_dimension",
    "riasec_type",
    "career_family",
    "career_job",
    "article",
    "faq_block",
    "cta"
  ],
  "edge_type_registry": [
    "topic_to_test",
    "topic_to_type",
    "type_to_career",
    "career_to_trait",
    "topic_to_article",
    "topic_to_faq",
    "topic_to_cta"
  ],
  "governance_fields": {
    "required": [
      "edge_id",
      "edge_type",
      "source_entity",
      "target_entity",
      "source_authority",
      "owner",
      "review_state",
      "visibility_state",
      "confidence",
      "evidence_requirement",
      "rendered_visibility"
    ],
    "review_states": [
      "draft",
      "reviewed",
      "approved",
      "deprecated"
    ],
    "visibility_states": [
      "candidate",
      "public",
      "private",
      "blocked"
    ],
    "source_authorities": [
      "backend_cms",
      "backend_public_api",
      "backend_sitemap_source",
      "migration_fixture"
    ],
    "rendered_visibility_states": [
      "visible_content",
      "not_rendered",
      "private_only"
    ]
  },
  "rules": [
    {
      "id": "graph-authority-backend-owned",
      "severity": "P0",
      "description": "Every graph edge must be backend/CMS or backend public API authoritative."
    },
    {
      "id": "public-edge-visible-content",
      "severity": "P0",
      "description": "Public graph edges must be grounded in visible rendered content, not hidden FAQ or schema."
    },
    {
      "id": "missing-route-cannot-be-public",
      "severity": "P0",
      "description": "Edges targeting blocked or missing public route entities must remain candidate or blocked until the entity is CMS-reviewed."
    },
    {
      "id": "no-runtime-rollout-from-contract",
      "severity": "P0",
      "description": "This contract fixture does not authorize public graph expansion or automatic link rendering."
    }
  ],
  "edge_fixtures": [
