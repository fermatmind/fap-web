{
  "version": "runtime.frontend_fallback_authority_inventory.v1",
  "scope": "PR-PRAC-03",
  "trainName": "public-runtime-authority-convergence-train",
  "runtimeBehaviorChanged": false,
  "fallbackClassificationEnum": [
    "safe_static",
    "product_code_only",
    "compatibility_wrapper",
    "watchlist",
    "migration_required",
    "forbidden"
  ],
  "hardRules": [
    "migration_required fallback cannot be silently added for new scale/test/page family",
    "forbidden fallback blocks merge when it becomes public authority",
    "compatibility_wrapper cannot be treated as long-term authority",
    "frontend fallback cannot become SEO truth",
    "frontend fallback cannot become graph truth",
    "frontend fallback cannot become recommendation truth"
  ],
  "requiredFallbacks": [
    "test_metadata_faq_cta_fallback",
    "topic_cta_fallback",
    "personality_fallback_projection",
    "article_jsonld_fallback",
    "llms_topic_fallback",
    "static_sitemap_layer",
    "local_recommendation_engine_placeholder"
  ],
  "rows": [
    {
      "id": "test_metadata_faq_cta_fallback",
      "surface": "test detail metadata, FAQ, and CTA fallback",
      "sources": ["app/(localized)/[locale]/tests/[slug]/page.tsx"],
      "requiredSourceTokens": ["normalizeLandingSurface", "parseFaq", "buildFAQPageJsonLd", "findLandingCta"],
      "classification": "migration_required",
      "canBecomePublicTruth": true,
      "seoGeoRisk": true,
      "graphRisk": false,
      "recommendationRisk": false,
      "claimBoundaryRisk": true,
      "expansionGate": "no_new_test_or_scale_fallback_without_backend_authority",
      "requiredFinalAuthority": "backend_scale_lookup_landing_answer_surface",
      "currentAllowance": "Compatibility only for existing test detail runtime.",
      "blocksWhen": "Added to new tests, new public surfaces, or new SEO/GEO exposure without backend/CMS authority."
    },
    {
      "id": "topic_cta_fallback",
      "surface": "topic detail CTA fallback",
      "sources": ["app/(localized)/[locale]/topics/[slug]/page.tsx"],
      "requiredSourceTokens": ["landingSurface?.ctaBundle", "localizedPath(\"/help/faq\", locale)"],
      "classification": "migration_required",
      "canBecomePublicTruth": true,
      "seoGeoRisk": true,
      "graphRisk": true,
      "recommendationRisk": false,
      "claimBoundaryRisk": true,
      "expansionGate": "no_topic_expansion_with_frontend_cta_truth",
      "requiredFinalAuthority": "cms_topic_landing_surface",
      "currentAllowance": "Existing topic detail compatibility only.",
      "blocksWhen": "Topic Graph, Topic SEO, or GEO expansion depends on frontend CTA fallback."
    },
    {
      "id": "personality_fallback_projection",
      "surface": "personality frontend fallback projection",
      "sources": ["app/(localized)/[locale]/personality/[type]/page.tsx"],
      "requiredSourceTokens": ["buildFallbackProjection", "frontend_gateway_fallback", "routeMode: \"fallback\""],
      "classification": "migration_required",
      "canBecomePublicTruth": true,
      "seoGeoRisk": false,
      "graphRisk": true,
      "recommendationRisk": true,
      "claimBoundaryRisk": true,
      "expansionGate": "no_personality_or_career_claim_expansion_on_fallback_projection",
      "requiredFinalAuthority": "cms_personality_projection_and_public_surfaces",
      "currentAllowance": "Noindex/schema-suppressed hard fallback only.",
      "blocksWhen": "Fallback projection is used for indexable schema, graph authority, recommendation authority, or career claims."
    },
    {
      "id": "article_jsonld_fallback",
      "surface": "Article JSON-LD frontend fallback",
      "sources": ["app/(localized)/[locale]/articles/[slug]/page.tsx"],
      "requiredSourceTokens": ["pathFromCanonicalUrl", "buildFAQPageJsonLd", "article.answerSurface"],
      "classification": "migration_required",
      "canBecomePublicTruth": true,
      "seoGeoRisk": true,
      "graphRisk": false,
      "recommendationRisk": false,
      "claimBoundaryRisk": true,
      "expansionGate": "no_article_or_geo_expansion_until_backend_jsonld_authority",
      "requiredFinalAuthority": "backend_cms_article_seo_jsonld",
      "currentAllowance": "Compatibility bridge for existing article detail pages.",
      "blocksWhen": "New article/GEO expansion relies on frontend-generated Article schema authority."
    },
    {
      "id": "llms_topic_fallback",
      "surface": "llms topic fallback exposure",
      "sources": ["app/llms.txt/route.ts", "app/llms-full.txt/route.ts"],
      "requiredSourceTokens": ["TOPIC_FALLBACK"],
      "classification": "migration_required",
      "canBecomePublicTruth": true,
      "seoGeoRisk": true,
      "graphRisk": true,
      "recommendationRisk": false,
      "claimBoundaryRisk": true,
      "expansionGate": "no_silent_llms_topic_exposure_widening",
      "requiredFinalAuthority": "backend_cms_topic_discoverability_authority",
      "currentAllowance": "Existing bounded fallback only.",
      "blocksWhen": "llms or llms-full topic exposure widens without fixture and backend/CMS authority."
    },
    {
      "id": "static_sitemap_layer",
      "surface": "static sitemap path layer",
      "sources": ["next-sitemap.config.js"],
      "requiredSourceTokens": ["additionalPaths", "buildLocalizedAuthorityCareerPath"],
      "classification": "compatibility_wrapper",
      "canBecomePublicTruth": true,
      "seoGeoRisk": true,
      "graphRisk": false,
      "recommendationRisk": false,
      "claimBoundaryRisk": false,
      "expansionGate": "no_static_sitemap_expansion_without_backend_fixture",
      "requiredFinalAuthority": "backend_sitemap_source_where_available",
      "currentAllowance": "Governed bridge for existing sitemap generation.",
      "blocksWhen": "Static sitemap additions bypass backend indexability and exposure fixtures."
    },
    {
      "id": "local_recommendation_engine_placeholder",
      "surface": "local career recommendation ranking placeholder",
      "sources": ["lib/career/recommendationEngine.ts"],
      "requiredSourceTokens": ["rankCareerRecommendations", "return []"],
      "classification": "forbidden",
      "canBecomePublicTruth": false,
      "seoGeoRisk": false,
      "graphRisk": true,
      "recommendationRisk": true,
      "claimBoundaryRisk": true,
      "expansionGate": "must_not_become_public_authority",
      "requiredFinalAuthority": "backend_recommendation_snapshot_or_future_governed_runtime",
      "currentAllowance": "Unused placeholder only.",
      "blocksWhen": "Local ranking is used as public recommendation, graph, SEO, or CTA authority."
    },
    {
      "id": "frontend_graph_hardcode",
      "surface": "frontend-local graph edge expansion",
      "sources": ["docs/graph/core-topic-graph-edge-schema.md"],
      "requiredSourceTokens": ["frontend-local graph authority", "frontend hardcoded graph expansion"],
      "classification": "forbidden",
      "canBecomePublicTruth": false,
      "seoGeoRisk": true,
      "graphRisk": true,
      "recommendationRisk": true,
      "claimBoundaryRisk": true,
      "expansionGate": "must_not_invent_frontend_graph_authority",
      "requiredFinalAuthority": "backend_cms_graph_edge_authority",
      "currentAllowance": "Documentation and internal candidate examples only.",
      "blocksWhen": "Frontend creates public graph edges or schema graph authority."
    },
    {
      "id": "homepage_forced_items",
      "surface": "homepage CMS-filtered product shell items",
      "sources": ["lib/marketing/homepageContent.ts"],
      "requiredSourceTokens": ["getCmsLandingSurfaceWithLastKnownGood", "filterVisiblePublicTestEntries"],
      "classification": "product_code_only",
      "canBecomePublicTruth": true,
      "seoGeoRisk": false,
      "graphRisk": false,
      "recommendationRisk": false,
      "claimBoundaryRisk": false,
      "expansionGate": "do_not_reclassify_as_seo_or_graph_authority",
      "requiredFinalAuthority": "cms_landing_surface_for_editorial_truth",
      "currentAllowance": "Product shell compatibility with CMS-authored items only; frontend forced quick-start completion has been removed.",
      "blocksWhen": "Product shell filtering or canonical href normalization is treated as SEO, graph, recommendation, or editorial truth."
    },
    {
      "id": "test_catalog_seed_fallback",
      "surface": "fallback public test catalog seeds",
      "sources": ["lib/content.ts"],
      "requiredSourceTokens": ["FALLBACK_PUBLIC_TEST_SEEDS", "buildFallbackPublicTests"],
      "classification": "watchlist",
      "canBecomePublicTruth": true,
      "seoGeoRisk": true,
      "graphRisk": false,
      "recommendationRisk": false,
      "claimBoundaryRisk": true,
      "expansionGate": "no_new_scale_or_test_from_frontend_seed",
      "requiredFinalAuthority": "backend_scale_catalog_and_lookup",
      "currentAllowance": "Existing test catalog compatibility.",
      "blocksWhen": "New tests or scales are exposed through frontend seed fallback."
    }
  ]
}
