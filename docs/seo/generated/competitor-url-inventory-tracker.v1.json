  "taxonomy": {
    "test_detail": {
      "definition": "A page whose primary intent is taking, starting, or explaining one assessment/test.",
      "common_url_patterns": ["/test/", "/tests/", "/personality-test", "/iq-test", "/enneagram-test", "/career-test"],
      "example_paths": ["/test/example-personality-test", "/tests/example-iq-test"],
      "confidence_rule": "high when test noun and singular test intent both appear; medium when only category path appears",
      "false_positive_notes": "Editorial pages about tests can be misclassified without future visible-page evidence."
    },
    "career_job": {
      "definition": "A specific occupation/job profile page.",
      "common_url_patterns": ["/career/", "/careers/", "/jobs/", "/occupation/", "/career-profiles/"],
      "example_paths": ["/careers/example-occupation", "/jobs/example-role"],
      "confidence_rule": "high when path indicates a specific occupation; medium for broad career category pages",
      "false_positive_notes": "Career advice pages are not job profiles."
    },
    "career_guide": {
      "definition": "A career advice, guide, or decision-support page that is not a specific occupation.",
      "common_url_patterns": ["/career-advice/", "/career-guide/", "/careers/article/"],
      "example_paths": ["/career-guide/example-topic", "/career-advice/example-guide"],
      "confidence_rule": "high when guide/advice term appears; medium when career path plus article format appears",
      "false_positive_notes": "Job listings and occupation pages must not be grouped here."
    },
    "article": {
      "definition": "Editorial or educational article page.",
      "common_url_patterns": ["/article/", "/articles/", "/blog/", "/learn/", "/health/"],
      "example_paths": ["/articles/example-topic", "/blog/example-note"],
      "confidence_rule": "high when article/blog path exists; medium when content hub path is broad",
      "false_positive_notes": "Tool landing pages and test pages often contain educational copy but are not articles."
    },
    "topic": {
      "definition": "A glossary, hub, type, category, or conceptual topic page.",
      "common_url_patterns": ["/topics/", "/types/", "/personality-types/", "/enneagram-types/", "/category/"],
      "example_paths": ["/topics/example-topic", "/personality-types/example-type"],
      "confidence_rule": "high when path is a stable topic/type hub; medium when category may be editorial",
      "false_positive_notes": "Topic hubs can overlap article lists; future HTML/title checks may refine."
    },
    "tool": {
      "definition": "A calculator, quiz launcher, comparison tool, or utility that is not a core assessment detail page.",
      "common_url_patterns": ["/tool/", "/tools/", "/calculator/", "/quiz/", "/compare/"],
      "example_paths": ["/tools/example-calculator", "/compare/example"],
      "confidence_rule": "high when utility term appears; medium when quiz may also be a test",
      "false_positive_notes": "Some tools are tests; prefer test_detail when assessment intent is primary."
    },
    "support": {
      "definition": "Help, FAQ, contact, policy, about, or support content.",
      "common_url_patterns": ["/help/", "/support/", "/faq/", "/about/", "/contact/", "/privacy", "/terms"],
      "example_paths": ["/help/example", "/faq"],
      "confidence_rule": "high for support/help/legal paths; medium for about/trust pages",
      "false_positive_notes": "Institutional trust pages may deserve separate future taxonomy."
    },
    "unknown": {
      "definition": "URL cannot be safely classified from URL shape alone.",
      "common_url_patterns": ["unmatched"],
      "example_paths": ["/example-path"],
      "confidence_rule": "low",
      "false_positive_notes": "Unknown must stay unknown rather than forcing an opportunity."
    }
  },
