  "backend_convergence_options": [
    {
      "id": "Option A",
      "title": "Migrate api.fermatmind.com to fap-api-prod / standard backend authority",
      "recommendation": "recommended_unless_blocked_by_live_api_compatibility",
      "pros": [
        "Aligns public API with standard Laravel release/runtime.",
        "Uses runtime where CMS/ops, scheduler, and queue workers are healthy.",
        "Reduces dual-SHA and dual-database ambiguity.",
        "Simplifies SEO Collector source selection."
      ],
      "cons": [
        "Requires careful parity validation.",
        "May expose route, auth, CORS, webhook, or cache behavior differences.",
        "Requires rollback plan before DNS/proxy change."
      ],
      "risks": [
        "Public clients may depend on legacy behavior.",
        "Payment webhooks or report/email gates may be routed differently.",
        "Session/auth/cookie behavior may differ."
      ],
      "required_validation": [
        "route parity",
        "auth/session parity",
        "payment webhook parity",
        "report/email gate parity",
        "CORS/origin parity",
        "rate-limit parity",
        "healthcheck parity",
        "queue/scheduler parity",
        "rollback plan",
        "DNS/proxy plan",
        "staged smoke"
      ],
      "seo_middle_platform_impact": "Best long-term option after gates pass."
    },
    {
      "id": "Option B",
      "title": "Keep fap-node2 as public API but standardize it",
      "pros": [
        "Avoids immediate DNS/API migration.",
        "Keeps current public API entry stable while cleaning drift."
      ],
      "cons": [
        "Requires substantial standardization work.",
        "Maintains two backend nodes unless gateway role is explicit."
      ],
      "risks": [
        "Legacy runtime may continue drifting.",
        "Local MySQL may diverge from managed business DB.",
        "Queue failure may hide async defects."
      ],
      "required_validation": [
        "Git/release provenance",
        "external DB/Redis alignment",
        "queue health",
        "same deploy contract",
        "explicit gateway role"
      ],
      "seo_middle_platform_impact": "Acceptable only after standardization and explicit authority contract."
    },
    {
      "id": "Option C",
      "title": "Keep split public API and ops backend intentionally",
      "pros": [
        "Allows dedicated public API and ops/CMS backend responsibilities.",
        "Can support a gateway pattern if explicitly designed."
      ],
      "cons": [
        "Requires formal gateway/backend boundary.",
        "Requires shared truth DB or explicit sync contract.",
        "Increases operational complexity."
      ],
      "risks": [
        "SEO 中台 may observe one truth while CMS edits another.",
        "Attribution may join against the wrong backend.",
        "Issue queue summaries may point to stale data."
      ],
      "required_validation": [
        "gateway/backend boundary",
        "same truth DB or documented sync semantics",
        "same contract version",
        "queue/scheduler ownership",
        "content release and revalidation ownership"
      ],
      "seo_middle_platform_impact": "Possible but more complex; collector inputs must explicitly name all authority sources."
    }
  ],
