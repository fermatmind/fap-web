{
  "version": "search_intelligence_data_contract.v1",
  "scope": "SEO-DASH-00B",
  "status": "contract_design",
  "source_documents": [
    "SEO-DASH-00A",
    "BACKEND-RUNTIME-02D",
    "ARCH-SEO-CMS-01",
    "ARCH-SEO-CMS-02"
  ],
  "source_of_truth_hierarchy": [
    {
      "rank": 1,
      "source": "backend_business_truth",
      "description": "Backend orders, payment events, and benefit grants owned by fap-api / Node3 authority."
    },
    {
      "rank": 2,
      "source": "backend_events",
      "description": "First-party backend events and backend daily read models."
    },
    {
      "rank": 3,
      "source": "fap_web_public_runtime",
      "description": "Deterministic public rendering and public URL observation surface."
    },
    {
      "rank": 4,
      "source": "search_engine_data",
      "description": "Google, Baidu, Bing/IndexNow, llms, and future channel adapter observations."
    },
    {
      "rank": 5,
      "source": "browser_analytics",
      "description": "GA4, Baidu Tongji, and ads telemetry."
    }
  ],
  "truth_rules": {
    "purchase_truth": "backend_orders_payment_benefit",
    "purchase_truth_not_ga4": true,
    "ga4_role": "behavior_telemetry_only",
    "baidu_tongji_role": "behavior_telemetry_only",
    "api_track_role": "transport_only",
    "api_track_final_source_of_truth": false,
    "node2_local_laravel_authority": false
  },
  "key_model": {
    "seo_url_key": ["canonical_url", "locale"],
    "page_entity_key": ["page_entity_type", "entity_id_or_slug", "locale"],
    "private_flows_excluded_from_seo_url_entities": true,
    "excluded_private_flows": [
      "result",
      "order",
      "take",
      "share",
      "pay",
      "checkout",
      "webhook",
      "email_bind",
      "report_download",
      "account",
      "auth",
      "token",
      "invite_accept",
      "recovery"
    ]
  },
  "page_entity_types": [
    "home",
    "test_hub",
    "test_detail",
    "article",
    "topic",
    "personality",
    "career_job",
    "career_recommendation",
    "methodology",
    "dataset",
    "report_preview",
    "landing_page"
  ],
  "funnel_event_taxonomy": {
    "canonical_events": [
      "start_attempt",
      "submit_attempt",
      "view_result",
      "click_unlock",
      "create_order",
      "payment_confirmed",
      "purchase_success"
    ],
    "legacy_aliases": {
      "pay_success": "purchase_success"
    },
    "secondary_events_role": "diagnostics_only"
  },
  "attribution_model": {
    "first_touch_window_days": 30,
    "last_touch_window_days": 7,
    "cta_touch_window": "same_session_or_24h",
    "purchase_truth": "backend_orders_payment_benefit",
    "keyword_direct_purchase_attribution_allowed": false,
    "search_query_role": "discovery_explanation_only",
    "session_unavailable_metric_rule": "use_explicit_proxy_names"
  },
  "search_channel_model": {
    "first_class_channels": [
      "google",
      "baidu",
      "bing_indexnow",
      "llms",
      "direct",
      "paid_google",
      "paid_baidu",
      "unknown"
    ],
    "reserved_planned_channels": [
      "so360",
      "sogou",
      "shenma",
      "quark",
      "ai_search"
    ],
    "china_search_engines_are_channel_adapters": true,
    "domestic_search_alternate_truth_allowed": false,
    "adapter_may_publish_content": false,
    "adapter_may_create_pseo": false
  },
  "pii_rules": {
    "forbidden_in_seo_intel_detail": [
      "email",
      "raw_cookies",
      "provider_event_id",
      "payment_payload",
      "raw_order_no",
      "raw_attempt_id",
      "auth_token",
      "bearer_token",
      "checkout_url",
      "report_url",
      "recovery_url",
      "payment_provider_payload"
    ],
    "raw_order_no_allowed_for_normal_dashboards": false,
    "raw_attempt_id_allowed_for_normal_dashboards": false,
    "allowed_references": [
      "masked_reference",
      "hashed_internal_reference",
      "aggregate_reference",
      "restricted_internal_reconciliation_id"
    ],
    "metabase_read_only": true,
    "metabase_may_query_raw_business_tables_directly": false
  },
  "consent_model": {
    "consent_state_required": true,
    "field": "consent_state",
    "allowed_values": [
      "analytics_granted",
      "analytics_denied",
      "unknown",
      "not_applicable_backend_business_event"
    ],
    "browser_event_without_analytics_consent_enters_marketing_analytics": false,
    "backend_business_events_aggregate_only_when_non_identifying": true,
    "third_party_tools_may_receive_pii": false
  },
  "internal_qa_filtering": {
    "traffic_labels": [
      "codex_qa",
      "controlled_pilot",
      "acceptance",
      "internal_ip",
      "test_user",
      "qa_email",
      "test_order",
      "bot_crawler_user_agent",
      "non_production_environment"
    ],
    "default_dashboard_excludes_internal_qa_bot_non_production": true,
    "test_purchases_contribute_to_revenue": false,
    "crawler_traffic_may_contribute_to_crawlability_diagnostics": true,
    "crawler_traffic_may_contribute_to_human_conversion_metrics": false
  },
  "revenue_model": {
    "source_of_truth": "backend_orders_payment_benefit",
    "exclude_statuses_or_types": [
      "pending",
      "failed",
      "cancelled",
      "refunded",
      "test_payment",
      "internal_qa_purchase"
    ],
    "metrics": [
      "revenue",
      "orders_count",
      "purchase_count",
      "AOV",
      "RPV",
      "purchase_rate"
    ],
    "aov_definition": "revenue / orders_count for accepted paid orders only",
    "purchase_rate_denominator_must_be_explicit": true,
    "sessions_unavailable_requires_rpv_proxy": true,
    "rpv_proxy_name": "RPV_proxy",
    "ga4_purchase_reconciliation_only": true
  },
  "semantic_claim_boundaries": {
    "forbidden_implications": [
      "RIASEC as complete career outcome recommender",
      "Big Five as career outcome recommender",
      "AI career planning",
      "diagnosis",
      "true IQ authority"
    ],
    "forbidden_metric_name_fragments": [
      "riasec_career_recommender",
      "big_five_career_recommender",
      "ai_career_planning",
      "diagnosis_score",
      "true_iq_authority"
    ],
    "allowed_naming_examples": [
      "career_support_view",
      "career_direction_page_view",
      "riasec_result_view",
      "workstyle_content_view",
      "interest_signal_page_view"
    ]
  },
  "logical_table_plan": {
    "migrations_created": false,
    "physical_schema_created": false,
    "tables": [
      "seo_urls",
      "seo_url_entities",
      "seo_event_funnel_daily",
      "seo_landing_attribution_daily",
      "seo_revenue_daily",
      "seo_cluster_daily",
      "seo_search_channel_status",
      "seo_consent_daily",
      "seo_internal_traffic_rules",
      "seo_issue_queue"
    ],
    "future_tables": [
      "seo_gsc_daily",
      "seo_baidu_push_logs",
      "seo_baidu_landing_daily",
      "seo_indexnow_submissions",
      "seo_crawler_logs_daily"
    ],
    "seo_intel_logically_isolated_from_business_db": true
  },
  "forbidden_actions": [
    "create_db_schema",
    "create_migrations",
    "implement_collector",
    "deploy_metabase",
    "connect_gsc",
    "connect_baidu",
    "connect_indexnow",
    "change_tracking",
    "change_payment",
    "change_order",
    "change_report",
    "change_email",
    "change_recommendation",
    "change_scoring",
    "change_sitemap",
    "change_llms",
    "change_env",
    "deploy",
    "ssh",
    "touch_production"
  ],
  "next_task": "SEO-DASH-01"
}
