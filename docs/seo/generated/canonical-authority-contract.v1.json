{
  "version": "seo.canonical_authority.v1",
  "scope": "PR-SEO-01C",
  "sitemapUrlSetChanged": false,
  "llmsExposureChanged": false,
  "schemaOrgChanged": false,
  "authority": {
    "backendCmsCanonical": "accepted_only_when_safe_public_route_consistent_locale_correct",
