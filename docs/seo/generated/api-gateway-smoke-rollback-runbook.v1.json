  "header_cors_cache_checks": {
    "origin": "https://fermatmind.com",
    "record": [
      "status code",
      "content-type",
      "CORS allow-origin behavior",
      "rate-limit header behavior if present",
      "cache headers",
      "HSTS observation if present",
      "robots/noindex headers if relevant"
    ],
    "forbidden_to_record": [
      "cookies",
      "bearer tokens",
      "session IDs",
      "raw authorization headers",
      "emails",
      "order numbers",
      "payment IDs",
      "webhook signatures",
      "private IDs"
    ]
  },
  "auth_session_checks": {
    "mode": "read_only",
    "allowed": [
      "verify unauthenticated public surfaces remain public",
      "verify private surfaces remain protected",
      "verify public responses do not leak unexpected cookies",
      "verify auth-required responses do not expose sensitive payloads"
    ],
    "forbidden": [
      "login",
      "password submission",
      "account mutation",
      "email binding",
      "token refresh",
      "session creation"
    ]
  },
  "report_email_checkout_checks": {
    "mode": "read_only_or_no_side_effect",
    "report_access": {
      "allowed_only_with_preexisting_safe_qa_attempt": true,
      "forbidden_without_qa_attempt": "state-changing report/email smoke"
    },
    "email_bind": {
      "forbidden_by_default": true,
      "allowed_only_with_explicit_qa_authorization": true
    },
    "checkout_order_creation": "forbidden",
    "payment": "forbidden",
    "mail_sending": "forbidden",
    "attempt_creation": "forbidden",
    "queue_triggering_endpoints": "forbidden"
  },
  "webhook_mapping_checks": {
    "mode": "mapping_only_non_triggering",
    "allowed": [
      "verify route presence from route inventory or config evidence",
      "verify provider endpoint path mapping",
      "verify webhook domain/path owner",
      "verify whether path enters Node2 gateway or Node3 directly",
      "verify gateway rewrite preserves signature headers"
    ],
    "forbidden": [
      "send fake payment event to production",
      "call provider webhook live",
      "replay captured webhooks",
      "create payment intents",
      "create orders",
      "print webhook secrets or signatures"
    ]
  },
  "backup_plan": {
    "status": [
      "future_change_window_only",
      "not_executed_by_this_pr"
    ],
    "steps": [
      "capture OpenResty config file path for api.fermatmind.com",
      "copy config to timestamped backup path",
      "record checksum for active config and backup",
      "record current upstream target for /api/",
      "preserve TLS blocks, server_name, redirects, ACME challenge blocks, and proxy header behavior",
      "validate syntax before reload",
      "prepare staged reload plan",
      "prepare rollback restore plan"
    ]
  },
  "rollback_plan": {
    "exists": true,
    "triggers": [
      "/api smoke failure",
      "auth/session regression",
      "CORS/header regression",
      "payment webhook ingress uncertainty",
      "report/email/checkout route regression",
      "unexpected 5xx or timeout increase",
      "proxy target drift",
      "TLS/server_name regression"
    ],
    "steps": [
      "stop the change window",
      "restore previous OpenResty config from timestamped backup",
      "validate OpenResty syntax",
      "reload OpenResty only inside approved change window",
      "re-run read-only gateway smoke checks",
      "communicate rollback result and remaining risk",
      "block dependent SEO-DASH work until smoke is green"
    ],
    "stop_conditions": [
      "backup missing",
      "syntax validation fails",
      "smoke remains red after rollback",
      "payment/report/email ingress is uncertain",
      "operator cannot prove active upstream target"
    ]
  },
  "acceptance_prerequisites_for_02c": [
    "gateway smoke runbook exists",
    "rollback plan exists",
    "Node2 local runtime remains quarantined",
    "Node3-backed public API smoke passes",
    "payment/report/email routes have non-side-effect mapping verified",
    "SEO Collector input source can be locked to Node3-backed authority",
    "forbidden side-effect operations remain out of smoke scope"
  ],
  "recommended_next_task": {
    "id": "BACKEND-RUNTIME-02C",
    "title": "API Gateway Read-only Smoke Evidence Capture",
    "seo_dash_00_recommended_now": false
