{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fermatmind.com/schemas/seo-cms-draft-package-contract.schema.json",
  "title": "FermatMind SEO CMS Draft Package Contract",
  "type": "object",
  "required": [
    "schema_version",
    "mode",
    "package_id",
    "target",
    "source_opportunities",
    "evidence_references",
    "proposed_draft",
    "claim_gate",
    "approvals_required",
    "forbidden_actions"
  ],
  "properties": {
    "schema_version": {
      "const": "fermatmind.seo_agent.cms_draft_package_contract.v1"
    },
    "mode": {
      "const": "dry_run_contract_only"
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "object",
      "required": ["url", "locale", "content_type"],
      "additionalProperties": true
    },
    "source_opportunities": {
      "type": "array",
      "minItems": 1
    },
    "evidence_references": {
      "type": "array",
      "minItems": 1
    },
    "proposed_draft": {
      "type": "object",
      "required": ["seo_title", "meta_description", "body_blocks", "media_policy"],
      "additionalProperties": true
    },
    "claim_gate": {
      "type": "object",
      "required": ["protocol", "claims"],
      "additionalProperties": true
    },
    "approvals_required": {
      "type": "array",
      "minItems": 1
    },
    "forbidden_actions": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}

