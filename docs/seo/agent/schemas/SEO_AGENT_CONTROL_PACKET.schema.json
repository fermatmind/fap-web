{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fermatmind.com/schemas/seo-agent-control-packet.schema.json",
  "title": "FermatMind SEO Agent Control Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "run_type",
    "generated_at",
    "generated_by",
    "mode",
    "repositories",
    "evidence_window",
    "source_summary",
    "evidence_items",
    "runtime_findings",
    "ops_dashboard_findings",
    "seo_intel_findings",
    "gsc_status",
    "cms_status",
    "search_channel_status",
    "candidate_actions",
    "blocked_actions",
    "approvals_required",
    "recommended_prs",
    "observation_windows",
    "gpt55_handoff",
    "final_verdict",
    "stop_conditions_triggered"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "fermatmind.seo_agent.control_packet.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 8
    },
    "run_type": {
      "type": "string",
      "enum": [
        "weekly",
        "manual",
        "pr_gate",
        "post_release_observation"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generated_by": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "read_only",
        "docs_only",
        "dry_run",
        "approved_execution"
      ]
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "path",
          "branch",
          "head_sha",
          "status"
        ],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "branch": { "type": "string" },
          "head_sha": { "type": "string" },
          "status": {
            "type": "string",
            "enum": [
              "clean",
              "dirty_unrelated",
              "dirty_scoped",
              "unknown"
            ]
          }
        }
      }
    },
    "evidence_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "started_at",
        "ended_at",
        "timezone"
      ],
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": { "type": "string", "format": "date-time" },
        "timezone": { "type": "string" }
      }
    },
    "source_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_summary_item" }
    },
    "evidence_items": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_item" }
    },
    "runtime_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "ops_dashboard_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "seo_intel_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "gsc_status": { "$ref": "#/$defs/status_block" },
    "cms_status": { "$ref": "#/$defs/status_block" },
    "search_channel_status": { "$ref": "#/$defs/status_block" },
    "candidate_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/action_item" }
    },
    "blocked_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/blocked_action" }
    },
    "approvals_required": {
      "type": "array",
      "items": { "$ref": "#/$defs/approval" }
    },
    "recommended_prs": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommended_pr" }
    },
    "observation_windows": {
      "type": "array",
      "items": { "$ref": "#/$defs/observation_window" }
    },
    "gpt55_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "packet_path",
        "review_questions",
        "authority_boundary"
      ],
      "properties": {
        "required": { "type": "boolean" },
        "packet_path": { "type": "string" },
        "review_questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "authority_boundary": { "type": "string" }
      }
    },
    "final_verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verdict",
        "recommended_lane",
        "summary"
      ],
      "properties": {
        "verdict": { "$ref": "#/$defs/verdict" },
        "recommended_lane": { "$ref": "#/$defs/action_lane" },
        "summary": { "type": "string" }
      }
    },
    "stop_conditions_triggered": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "source_class": {
      "type": "string",
      "enum": [
        "LIVE_API",
        "STATIC_ARTIFACT",
        "MOCK",
        "FIXTURE",
        "GENERATED_ARTIFACT",
        "UNKNOWN",
        "ACCESS_REQUIRED",
        "MIXED"
      ]
    },
    "evidence_label": {
      "type": "string",
      "enum": [
        "VERIFIED",
        "NOT_VERIFIED",
        "ACCESS_REQUIRED",
        "NEEDS_OPERATOR_CONFIRMATION",
        "UNKNOWN"
      ]
    },
    "action_lane": {
      "type": "string",
      "enum": [
        "DOCS_ONLY_PR",
        "RUNTIME_QA_READONLY",
        "OPS_READMODEL_BRIDGE",
        "GSC_DATA_QUALITY_READONLY",
        "OPPORTUNITY_QUEUE_READONLY",
        "CMS_DRAFT_PACKAGE_DRY_RUN",
        "SEARCH_READINESS_REPORT",
        "BLOCKED_MUTATION"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "GO",
        "CONDITIONAL_GO",
        "HOLD",
        "BLOCKED",
        "NEEDS_MORE_EVIDENCE"
      ]
    },
    "source_summary_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_name",
        "source_class",
        "evidence_label",
        "authority_rank",
        "allowed_use",
        "forbidden_use"
      ],
      "properties": {
        "source_id": { "type": "string" },
        "source_name": { "type": "string" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "component_sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_class" }
        },
        "evidence_label": { "$ref": "#/$defs/evidence_label" },
        "authority_rank": { "type": "integer", "minimum": 1 },
        "allowed_use": { "type": "string" },
        "forbidden_use": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_id",
        "evidence_label",
        "summary"
      ],
      "properties": {
        "id": { "type": "string" },
        "source_id": { "type": "string" },
        "evidence_label": { "$ref": "#/$defs/evidence_label" },
        "file_path": { "type": "string" },
        "route": { "type": "string" },
        "command": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "evidence_label",
        "source_class",
        "severity",
        "summary",
        "recommended_lane"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "evidence_label": { "$ref": "#/$defs/evidence_label" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "component_sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_class" }
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "blocked"
          ]
        },
        "summary": { "type": "string" },
        "recommended_lane": { "$ref": "#/$defs/action_lane" },
        "requires_human_confirmation": { "type": "boolean" }
      }
    },
    "status_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_label",
        "source_class",
        "summary",
        "can_drive_actions"
      ],
      "properties": {
        "evidence_label": { "$ref": "#/$defs/evidence_label" },
        "source_class": { "$ref": "#/$defs/source_class" },
        "summary": { "type": "string" },
        "can_drive_actions": { "type": "boolean" },
        "blocked_reason": { "type": "string" }
      }
    },
    "action_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "lane",
        "verdict",
        "summary",
        "risk",
        "requires_approval"
      ],
      "properties": {
        "id": { "type": "string" },
        "lane": { "$ref": "#/$defs/action_lane" },
        "verdict": { "$ref": "#/$defs/verdict" },
        "summary": { "type": "string" },
        "risk": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "requires_approval": { "type": "boolean" }
      }
    },
    "blocked_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "reason",
        "required_approval"
      ],
      "properties": {
        "action": { "type": "string" },
        "reason": { "type": "string" },
        "required_approval": { "type": "string" }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_id",
        "action",
        "required_phrase",
        "required_before_lane"
      ],
      "properties": {
        "approval_id": { "type": "string" },
        "action": { "type": "string" },
        "required_phrase": { "type": "string" },
        "required_before_lane": { "$ref": "#/$defs/action_lane" }
      }
    },
    "recommended_pr": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "order",
        "verdict",
        "scope",
        "dependencies"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "integer", "minimum": 1 },
        "verdict": { "$ref": "#/$defs/verdict" },
        "scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    },
    "observation_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window",
        "purpose",
        "metrics",
        "rollback_conditions",
        "expand_conditions"
      ],
      "properties": {
        "window": {
          "type": "string",
          "enum": [
            "D1",
            "D7",
            "D14",
            "D28"
          ]
        },
        "purpose": { "type": "string" },
        "metrics": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rollback_conditions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expand_conditions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
