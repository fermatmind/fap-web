    },
    {
      "id": "pdf_private_print_gate",
      "status": "PASS",
      "evidence": "PDF and private print remain report-access governed, backend-authored, private/no-store, and redaction-contract covered."
    },
    {
      "id": "public_private_content_separation_gate",
      "status": "PASS",
      "evidence": "Private RIASEC result/report/history/payment surfaces remain noindex/private and do not become public SEO, sitemap, llms, canonical, JSON-LD, hreflang, or search-submission authority."
