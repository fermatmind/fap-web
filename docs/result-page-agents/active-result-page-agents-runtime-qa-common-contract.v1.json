  "assertion_vocabulary": [
    {
      "id": "route_contract",
      "description": "The result-page route is mapped to the reviewed result-page agent and does not create a parallel public surface."
    },
    {
      "id": "report_api_contract",
      "description": "The report API contract is represented by existing public-safe contract evidence and does not expose private payloads."
    },
    {
      "id": "report_access_api_contract",
      "description": "The report-access API contract keeps token, account, and private fields out of public artifacts."
    },
    {
      "id": "renderer_dispatch",
      "description": "The result renderer dispatches only through the reviewed agent shell or component path."
    },
    {
      "id": "pdf_private_print_boundary",
      "description": "PDF and private print behavior keeps private URLs, tokens, and raw data out of public or exported surfaces."
    },
    {
      "id": "share_public_private_boundary",
      "description": "Share surfaces remain public-summary only and block private or internal fields."
    },
    {
      "id": "private_result_noindex_boundary",
      "description": "Private result surfaces remain non-indexable and must not add canonical, schema, hreflang, or search exposure."
    },
    {
      "id": "leak_boundary",
      "description": "Runtime QA must fail closed if raw scores, private IDs, tokens, traces, payloads, or fallback content appear."
    },
    {
      "id": "claim_privacy_safety_gate",
      "description": "Unsupported deterministic, diagnostic, hiring, salary, success, admission, ability, or life-outcome claims remain forbidden."
    },
    {
      "id": "analytics_smoke_exclusion_gate",
      "description": "Analytics smoke evidence may record public-safe event classes only and must exclude private payloads."
    }
  ],
