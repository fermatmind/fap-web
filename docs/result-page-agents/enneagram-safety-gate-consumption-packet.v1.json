  "safety_assertions": [
    {
      "id": "unsupported_claim_gate",
      "status": "PASS",
      "evidence": "Blocks final type certainty, fixed type certainty, diagnostic, therapy, treatment, hiring, salary, performance, success, admission, ability, and life-outcome claims."
    },
    {
      "id": "private_result_boundary_gate",
      "status": "PASS",
      "evidence": "Blocks attempt identifiers, raw scores, score vectors, dominance gaps, release hashes, raw/internal metadata, private payloads, private report text, tokens, private URLs, account identifiers, and payment/order identifiers."
    },
    {
      "id": "analytics_payload_privacy_gate",
      "status": "PASS",
      "evidence": "Analytics packet allows read-only quality report planning only and blocks event emission, production metric backfill, opportunity scoring, private payload emission, and generated readiness analytics."
    },
    {
      "id": "share_public_summary_gate",
      "status": "PASS",
      "evidence": "Enneagram share remains public-summary scoped and does not expose private/internal result fields."
    },
    {
      "id": "pdf_private_print_gate",
      "status": "PASS",
      "evidence": "PDF and private print remain private-safe and must not expose private URLs, raw scores, report tokens, or full private report text."
    },
    {
      "id": "public_private_content_separation_gate",
      "status": "PASS",
      "evidence": "Private Enneagram result text must not become public personality profile content or SEO content authority."
    },
    {
      "id": "source_classification_gate",
      "status": "PASS",
      "evidence": "Public share and public profile boundary evidence are source-classified as consumer contract evidence, not CMS, runtime, import, activation, or production authority."
    },
    {
      "id": "hard_hold_action_gate",
      "status": "PASS",
      "evidence": "Candidate generation, import, activation, runtime switch, public profile mutation, CMS, search, private data, event emission, backfill, opportunity scoring, provider calls, generated writes, deploy, production import, rollout, and fap-api mutation remain held."
    },
    {
      "id": "smoke_exclusion_gate",
      "status": "PASS",
      "evidence": "Smoke, test, QA, synthetic, fixture, generated, staging-only, provider/search/deploy, and private result URL observations are excluded from approval."
    },
    {
      "id": "runtime_qa_to_analytics_safety_gate",
      "status": "PASS",
      "evidence": "Runtime QA and Analytics readiness can feed a read-only Safety Gate report but cannot approve runtime, production, CMS, search, private-data, event-emission, backfill, opportunity-scoring, or public-profile mutation actions."
    },
    {
      "id": "production_mutation_hold_gate",
      "status": "PASS",
