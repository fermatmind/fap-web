    "report_ready": "ga4_report_ready",
    "private_url_seen": "ga4_private_url_seen_safety_anomaly"
  },
  "ga4KeyEventTaxonomy": {
    "landing_pv": "page_view",
    "article_to_test_click": "article_to_test_click",
    "start_test": "test_start",
    "complete_test": "test_complete",
    "view_result": "result_view",
    "click_deep_report": "report_click",
    "begin_checkout": "checkout_begin",
    "purchase_success": "payment_success",
    "report_unlock": "report_unlock",
    "report_ready": "report_ready",
    "private_url_seen": "private_url_seen"
  },
  "baiduTongjiConversionTaxonomy": {
    "test_start": {
      "category": "test",
      "action": "start"
    },
    "test_complete": {
      "category": "test",
      "action": "complete"
    },
    "result_view": {
      "category": "result",
      "action": "view"
    },
    "report_click": {
      "category": "report",
      "action": "click"
    },
    "checkout_begin": {
      "category": "checkout",
      "action": "begin"
    },
    "payment_success": {
      "category": "purchase",
      "action": "success"
    },
    "report_unlock": {
      "category": "report",
      "action": "success"
    },
    "report_ready": {
      "category": "report",
      "action": "view"
    }
  },
  "canonicalFunnelEvents": [
    "start_test",
    "complete_test",
    "view_result",
    "click_deep_report",
    "begin_checkout",
    "purchase_success"
  ],
  "legacyAliasMapping": {
    "view_landing": "landing_pv",
    "landing_view": "landing_pv",
    "start_attempt": "start_test",
    "start_click": "start_test",
    "clinical_start": "start_test",
    "submit_attempt": "complete_test",
    "submit_click": "complete_test",
    "clinical_submit": "complete_test",
    "report_view_free": "view_result",
    "clinical_report_view": "view_result",
    "riasec_result_view": "view_result",
    "click_unlock": "click_deep_report",
    "create_order": "begin_checkout",
    "checkout_start": "begin_checkout",
    "clinical_checkout_start": "begin_checkout",
    "purchase": "purchase_success",
    "pay_success": "purchase_success",
    "unlock_success": "report_unlock",
    "clinical_unlock_success": "report_unlock",
    "report_loaded": "report_ready"
