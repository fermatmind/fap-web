{
  "version": "tracking.activation_contract.v1",
  "ga4Loader": "enabled_by_env",
  "baiduTongjiLoader": "enabled_by_env",
  "googleAdsConversionBridge": "enabled_by_env",
  "gtmEnabled": false,
  "baiduAdsEnabled": false,
  "requiredProductionEnv": [
    "NEXT_PUBLIC_ANALYTICS_ENABLED",
    "NEXT_PUBLIC_GA_MEASUREMENT_ID",
    "NEXT_PUBLIC_BAIDU_TONGJI_ID",
    "NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID",
    "NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION_LABEL"
  ],
  "optionalReservedEnv": [
    "NEXT_PUBLIC_BAIDU_SITE_VERIFICATION",
    "NEXT_PUBLIC_GOOGLE_ADS_TEST_SUBMIT_CONVERSION_LABEL",
    "NEXT_PUBLIC_GOOGLE_ADS_BEGIN_CHECKOUT_CONVERSION_LABEL"
  ],
  "eventMapping": {
    "start_attempt": "ga4_start_test",
    "submit_attempt": "ga4_complete_test",
    "view_result": "ga4_view_result",
    "click_unlock": "ga4_click_deep_report",
    "create_order": "ga4_begin_checkout",
    "payment_confirmed": "ga4_add_payment_info",
    "purchase_success": "ga4_purchase_success_and_google_ads_purchase_conversion"
  },
  "ga4KeyEventTaxonomy": {
    "start_attempt": "start_test",
    "submit_attempt": "complete_test",
    "view_result": "view_result",
    "click_unlock": "click_deep_report",
    "create_order": "begin_checkout",
    "purchase_success": "purchase_success"
  },
  "baiduTongjiConversionTaxonomy": {
    "start_test": {
      "category": "test",
      "action": "start"
    },
    "complete_test": {
      "category": "test",
      "action": "complete"
    },
    "view_result": {
      "category": "result",
      "action": "view"
    },
    "click_deep_report": {
      "category": "report",
      "action": "click"
    },
    "begin_checkout": {
      "category": "checkout",
      "action": "begin"
    },
    "purchase_success": {
      "category": "purchase",
      "action": "success"
    }
  },
  "canonicalFunnelEvents": [
    "start_attempt",
    "submit_attempt",
    "view_result",
    "click_unlock",
    "create_order",
    "payment_confirmed",
    "purchase_success"
  ],
  "legacyAliasMapping": {
    "start_click": "start_attempt",
    "clinical_start": "start_attempt",
    "submit_click": "submit_attempt",
    "clinical_submit": "submit_attempt",
    "report_view_free": "view_result",
    "clinical_report_view": "view_result",
    "riasec_result_view": "view_result",
    "checkout_start": "create_order",
    "clinical_checkout_start": "create_order",
    "pay_success": "purchase_success"
  },
  "adsPrimaryConversion": "purchase_success",
  "adsDisabledEvents": [
    "start_attempt",
    "submit_attempt",
    "view_result",
    "click_unlock",
    "create_order",
    "payment_confirmed"
  ],
  "googleAdsPayloadPolicy": {
    "send_to": "NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID/NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION_LABEL",
    "value": "amount_then_value_then_price_when_present",
    "currency": "payload_currency_only_no_default",
    "transaction_id": "not_sent_by_google_ads_bridge"
  },
  "realIdsCommitted": false,
  "runtimeBehaviorChanged": true,
  "seoGeoChanged": false,
  "recommendationChanged": false,
  "profileMemoryChanged": false,
  "checkoutChanged": false,
  "reportEntitlementChanged": false
}
