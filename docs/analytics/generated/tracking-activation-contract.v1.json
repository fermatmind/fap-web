{
  "version": "tracking.activation_contract.v1",
  "ga4Loader": "enabled_by_env",
  "baiduTongjiLoader": "enabled_by_env",
  "googleAdsConversionBridge": "enabled_by_env",
  "gtmEnabled": false,
  "baiduAdsEnabled": false,
  "requiredProductionEnv": [
    "NEXT_PUBLIC_ANALYTICS_ENABLED",
    "NEXT_PUBLIC_GA_MEASUREMENT_ID",
    "NEXT_PUBLIC_BAIDU_TONGJI_ID",
    "NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID",
    "NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION_LABEL"
  ],
  "optionalReservedEnv": [
    "NEXT_PUBLIC_BAIDU_SITE_VERIFICATION",
    "NEXT_PUBLIC_GOOGLE_ADS_TEST_SUBMIT_CONVERSION_LABEL",
    "NEXT_PUBLIC_GOOGLE_ADS_BEGIN_CHECKOUT_CONVERSION_LABEL"
  ],
  "eventMapping": {
