{
  "version": "tracking.activation_contract.v1",
  "ga4Loader": "enabled_by_env",
  "baiduTongjiLoader": "enabled_by_env",
  "googleAdsConversionBridge": "enabled_by_env",
  "gtmEnabled": false,
  "baiduAdsEnabled": false,
  "requiredProductionEnv": [
    "NEXT_PUBLIC_ANALYTICS_ENABLED",
    "NEXT_PUBLIC_GA_MEASUREMENT_ID",
    "NEXT_PUBLIC_BAIDU_TONGJI_ID",
    "NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID",
    "NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION_LABEL"
  ],
  "optionalReservedEnv": [
    "NEXT_PUBLIC_BAIDU_SITE_VERIFICATION",
    "NEXT_PUBLIC_GOOGLE_ADS_TEST_SUBMIT_CONVERSION_LABEL",
    "NEXT_PUBLIC_GOOGLE_ADS_BEGIN_CHECKOUT_CONVERSION_LABEL"
  ],
  "eventMapping": {
    "create_order": "ga4_begin_checkout",
    "payment_confirmed": "ga4_add_payment_info",
    "purchase_success": "ga4_purchase_and_google_ads_purchase_conversion",
    "pay_success": "ga4_purchase_and_google_ads_purchase_conversion"
  },
  "adsPrimaryConversion": "purchase_success",
  "adsDisabledEvents": [
    "start_attempt",
    "submit_attempt",
    "view_result",
    "click_unlock",
    "create_order",
    "payment_confirmed"
  ],
  "googleAdsPayloadPolicy": {
    "send_to": "NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID/NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION_LABEL",
    "value": "amount_then_value_then_price_when_present",
    "currency": "payload_currency_only_no_default",
    "transaction_id": "order_no_then_orderNo_then_order_id_then_transaction_id_when_present"
  },
  "realIdsCommitted": false,
  "runtimeBehaviorChanged": true,
  "seoGeoChanged": false,
  "recommendationChanged": false,
  "profileMemoryChanged": false,
  "checkoutChanged": false,
  "reportEntitlementChanged": false
}
