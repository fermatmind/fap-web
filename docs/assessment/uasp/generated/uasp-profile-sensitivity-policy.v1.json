  "profileContributionPolicy": [
    {
      "profile_contribution": "none",
      "meaning": "Signal does not contribute to profile memory.",
      "allowedRetention": [
        "no_profile_storage"
      ],
      "requiresFutureConsentPolicy": false
    },
    {
      "profile_contribution": "summary_only",
      "meaning": "Signal may appear as a non-longitudinal summary when product policy allows it.",
      "allowedRetention": [
        "summary_storage"
      ],
      "requiresFutureConsentPolicy": false
    },
    {
      "profile_contribution": "longitudinal",
      "meaning": "Signal may contribute to longitudinal profile interpretation when the scale is not sensitive and has versioned interpretation.",
      "allowedRetention": [
        "longitudinal_storage"
      ],
      "requiresFutureConsentPolicy": false
    },
    {
      "profile_contribution": "sensitive_opt_in",
