      "allowedRetention": [
        "opt_in_sensitive_storage"
      ],
      "requiresFutureConsentPolicy": true
    },
    {
      "profile_contribution": "ephemeral",
      "meaning": "Signal describes a temporary state and must not be frozen as a stable trait.",
      "allowedRetention": [
        "session_only"
      ],
      "requiresFutureConsentPolicy": false
    },
    {
      "profile_contribution": "blocked",
      "meaning": "Signal is blocked from profile contribution.",
      "allowedRetention": [
        "blocked_storage"
      ],
      "requiresFutureConsentPolicy": false
