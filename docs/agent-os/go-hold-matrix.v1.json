{
  "schema_version": "fermatmind.go_hold_matrix.v1",
  "created_at": "2026-06-22",
  "scope": "agent_os_registry_go_hold_matrix",
  "mode": "docs_contracts_only",
  "state_definitions": {
    "GO_DOCS_CONTRACTS_ONLY": "May create or update docs, contracts, schemas, examples, and proposal artifacts inside the declared scope.",
    "GO_READONLY_QA": "May run read-only local or public QA and produce sanitized evidence artifacts.",
    "GO_READONLY_HOLD_MUTATION": "May collect/classify evidence and produce recommendations; all mutations remain held.",
    "GO_DRY_RUN_ONLY": "May generate dry-run packages and review artifacts only.",
    "GO_SCAFFOLD_DOCS_ONLY": "May scaffold runbooks, schemas, readiness templates, and implementation proposals only.",
    "GO_ALIGN_DOCS_AND_READONLY_CHECKS": "May align existing agent docs/contracts and run read-only checks.",
    "GO_ASSET_PLANNING_HOLD_DETERMINISTIC_RECOMMENDATION": "May plan or audit content assets; deterministic recommendation claims remain held.",
    "GO_PACKAGE_PLANNING_HOLD_PUBLISH": "May generate package planning artifacts; publish/import/search release remains held.",
    "GO_RESEARCH_ONLY_HOLD_PAGE_GENERATION": "May inspect public sources and summarize patterns; page generation remains held.",
    "GO_GATE_ENFORCEMENT": "May block claims, unsafe actions, and privacy leaks.",
    "HOLD_EXACT_APPROVAL": "Must not execute until exact action-specific human approval exists.",
    "BLOCKED": "Must stop until missing authority, evidence, dependency, or safety issue is resolved."
  },
