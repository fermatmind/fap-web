  "approval_states": [
    "not_requested",
    "review_requested",
    "approved_for_dry_run_only",
    "approved_for_single_canary_write",
    "approved_for_publish_or_submit",
    "rejected"
  ],
  "readiness_states": [
    "ready_docs_contract",
    "ready_readonly_control",
    "ready_dry_run_contract",
    "ready_gate_contract",
    "partial_ready_readonly",
    "partial_six_hub_runtime",
    "partial_asset_factory",
    "partial_profile_agent",
    "partial_hold_scoring",
    "proposal_ready",
    "research_only",
    "hold_exact_approval_required",
    "missing_agent_stack",
    "existing_agent_stack_align_required",
    "blocked_missing_backend_authority",
    "blocked_private_data_required"
  ],
  "hard_hold_actions": [
    "automatic_cms_publish",
    "automatic_search_submission",
    "gsc_request_indexing",
    "google_indexing_api",
    "baidu_push",
    "indexnow_submit",
    "search_channel_enqueue",
    "search_channel_approve",
    "search_channel_submit",
    "production_env_changes",
    "payment_order_mutation",
    "private_result_indexing",
    "raw_private_result_access",
    "deterministic_career_recommendation",
    "iq_eq_diagnostic_guarantee",
    "schema_hreflang_sitemap_llms_mutation_without_exact_approval"
  ],
  "common_stop_conditions": [
    "changed_files_outside_declared_scope",
    "mock_fixture_unknown_or_stale_data_would_drive_production_action",
    "default_denied_action_without_exact_human_approval",
    "raw_private_result_attempt_order_payment_pii_or_credential_access_required",
    "source_truth_conflict_without_backend_authority_resolution",
    "artifact_contains_unsanitized_private_or_secret_material"
  ],
  "artifact_contract": {
    "required_fields": [
      "schema_version",
      "artifact_id",
      "created_at",
      "producing_agent_id",
      "receiving_agent_id",
      "source_refs",
      "evidence_labels",
      "approval_state",
      "allowed_next_actions",
      "forbidden_actions",
      "negative_guarantees",
      "checks",
      "stop_conditions",
      "next_goal"
    ],
    "file_reference_fields": [
      "path",
      "byte_size",
      "sha256",
      "schema_version",
      "sanitized_summary"
    ]
  },
