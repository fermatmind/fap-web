# Public API origin used by the shared frontend API resolver.
#
# Production:
# NEXT_PUBLIC_API_URL=https://api.fermatmind.com
#
# Daily frontend development / preview / IAB review:
# NEXT_PUBLIC_API_URL=https://staging-api.fermatmind.com
#
# Backend/CMS local integration only:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
#
# Keep local API mode out of default frontend review unless the backend CMS
# server and baseline content are intentionally running locally.
NEXT_PUBLIC_API_URL=https://api.fermatmind.com

# Must be set to your real production domain before launch.
NEXT_PUBLIC_SITE_URL=https://fermatmind.com
CSP_NONCE_MODE=enforce

# Optional site verification tags
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BAIDU_SITE_VERIFICATION=
REQUIRED_EN_TRANSLATION_GROUPS=mbti-basics,mbti-growth-guide,mbti-narrative-portrait,big-five-tool-guide,big-five-growth-guide,big-five-narrative-portrait,clinical-depression-anxiety-pro-tool-guide,clinical-depression-anxiety-pro-growth-guide,clinical-depression-anxiety-pro-narrative-portrait,depression-screening-standard-tool-guide,depression-screening-standard-growth-guide,depression-screening-standard-narrative-portrait,iq-test-tool-guide,iq-test-growth-guide,iq-test-narrative-portrait,eq-test-tool-guide,eq-test-growth-guide,eq-test-narrative-portrait

# Public analytics activation. Keep IDs empty in repository examples.
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_BAIDU_TONGJI_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_TEST_SUBMIT_CONVERSION_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_BEGIN_CHECKOUT_CONVERSION_LABEL=
NEXT_PUBLIC_EMAIL_CAPTURE_ENABLED=false
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_RELEASE=
NEXT_PUBLIC_IMMERSIVE_SINGLE_FLOW_ENABLED=true
CONTENT_RELEASE_REVALIDATE_SECRET=
CONTENT_RELEASE_REVALIDATE_TOLERANCE_SECONDS=300
CONTENT_RELEASE_REVALIDATE_RATE_LIMIT=60
CONTENT_RELEASE_REVALIDATE_REDIS_URL=
CONTENT_RELEASE_REVALIDATE_REDIS_TOKEN=
TRACK_INGEST_TOKEN=
MBTI_ATTRIBUTION_INGEST_ENDPOINT=
CAREER_ATTRIBUTION_INGEST_ENDPOINT=
ANALYTICS_ENDPOINT=
EDM_ENDPOINT=

# Scale-level rollout switches (operations gate)
ENABLE_MBTI=true
ENABLE_BIG5_OCEAN=true
ENABLE_SDS_20=true
ENABLE_CLINICAL_COMBO_68=true

# Stable bucket rollout percentage by anonymous id (0-100)
ROLLOUT_PERCENT_MBTI=100
ROLLOUT_PERCENT_BIG5_OCEAN=100
ROLLOUT_PERCENT_SDS_20=100
ROLLOUT_PERCENT_CLINICAL_COMBO_68=100

# Crisis-scale commerce kill switches
ENABLE_SDS_20_COMMERCE=true
ENABLE_CLINICAL_COMBO_68_COMMERCE=true

# Report availability resilience toggles
NEXT_PUBLIC_REPORT_404_RETRY_ENABLED=true
NEXT_PUBLIC_REPORT_404_RETRY_MAX=5
NEXT_PUBLIC_REPORT_404_RETRY_SCHEDULE_MS=1000,2000,4000,6000,8000
NEXT_PUBLIC_GENERATING_SHOW_PAYWALL=true

# Staging-only career salary asset preview consumer.
# Enables the 10-slug allowlisted preview API reader; production defaults closed.
FAP_CAREER_SALARY_ASSET_PREVIEW_ENABLED=false
