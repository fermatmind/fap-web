# Public API endpoint used by Next.js rewrites.
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_BASE=/api

# Must be set to your real production domain before launch.
NEXT_PUBLIC_SITE_URL=https://fermatmind.com

# Optional site verification tags
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BAIDU_SITE_VERIFICATION=
REQUIRED_EN_TRANSLATION_GROUPS=mbti-basics,mbti-growth-guide,mbti-narrative-portrait,big-five-tool-guide,big-five-growth-guide,big-five-narrative-portrait,clinical-depression-anxiety-pro-tool-guide,clinical-depression-anxiety-pro-growth-guide,clinical-depression-anxiety-pro-narrative-portrait,depression-screening-standard-tool-guide,depression-screening-standard-growth-guide,depression-screening-standard-narrative-portrait,iq-test-tool-guide,iq-test-growth-guide,iq-test-narrative-portrait,eq-test-tool-guide,eq-test-growth-guide,eq-test-narrative-portrait

NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_EMAIL_CAPTURE_ENABLED=false
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_RELEASE=
NEXT_PUBLIC_IMMERSIVE_SINGLE_FLOW_ENABLED=true
TRACK_INGEST_TOKEN=
ANALYTICS_ENDPOINT=
EDM_ENDPOINT=

# Scale-level rollout switches (operations gate)
ENABLE_MBTI=true
ENABLE_BIG5_OCEAN=true
ENABLE_SDS_20=true
ENABLE_CLINICAL_COMBO_68=true

# Stable bucket rollout percentage by anonymous id (0-100)
ROLLOUT_PERCENT_MBTI=100
ROLLOUT_PERCENT_BIG5_OCEAN=100
ROLLOUT_PERCENT_SDS_20=100
ROLLOUT_PERCENT_CLINICAL_COMBO_68=100

# Crisis-scale commerce kill switches
ENABLE_SDS_20_COMMERCE=true
ENABLE_CLINICAL_COMBO_68_COMMERCE=true

# CDN and COS upload settings
NEXT_PUBLIC_CDN_URL=
COS_UPLOAD_ENABLED=false
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_BUCKET=
COS_PATH_PREFIX=
